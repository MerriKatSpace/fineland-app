      const loanScheduleWrapperEl = document.getElementById("loanScheduleWrapper");
      const loanScheduleBodyEl = document.getElementById("loanScheduleBody");
      const resultYear1BreakdownEl = document.getElementById("resultYear1Breakdown");
      const resultY1TotalRentEl = document.getElementById("resultY1TotalRent");
      const resultY1PrincipalPaidEl = document.getElementById("resultY1PrincipalPaid");
      const resultY1InterestPaidEl = document.getElementById("resultY1InterestPaid");
      const resultY1PrincipalInterestPaidEl = document.getElementById(
        "resultY1PrincipalInterestPaid",
      );
      const resultY1BalanceEndEl = document.getElementById("resultY1BalanceEnd");
      const resultY1ProfitMarginEl = document.getElementById("resultY1ProfitMargin");

      /**
       * Logic (JS): định dạng vi-VN — hàng nghìn bằng dấu chấm, thập phân bằng dấu phẩy
       * (ví dụ 10.000,01), đồng bộ với ô nhập (.js-vn-number).
       */
      function formatViVnAmount(value, maxFractionDigits = 2) {
        return Number(value).toLocaleString("vi-VN", {
          minimumFractionDigits: 0,
          maximumFractionDigits: maxFractionDigits,
        });
      }

      /** Chuỗi nhập → nội bộ digits + một dấu chấm thập phân (giống Number). */
      function vnRawToClean(raw, maxDecimals) {
        let s = String(raw ?? "")
          .replace(/\s/g, "")
          .replace(/[^\d.,]/g, "");
        const lc = s.lastIndexOf(",");
        if (lc !== -1) {
          let intSide = s.slice(0, lc).replace(/\./g, "").replace(/[^\d]/g, "");
          let fracSide = s.slice(lc + 1).replace(/[^\d]/g, "").slice(0, maxDecimals);
          if (s.endsWith(",") && fracSide === "") {
            if (intSide === "") return "0.";
            return intSide + ".";
          }
          if (fracSide.length > 0) return (intSide || "0") + "." + fracSide;
          return intSide;
        }
        const firstDot = s.indexOf(".");
        if (firstDot !== -1) {
          const after = s.slice(firstDot + 1);
          if (!after.includes(".")) {
            const onlyDigitsAfter = after.replace(/[^\d]/g, "");
            if (onlyDigitsAfter.length > 0 && onlyDigitsAfter.length <= maxDecimals) {
              const intSide = s.slice(0, firstDot).replace(/\./g, "").replace(/[^\d]/g, "");
              return intSide + "." + onlyDigitsAfter.slice(0, maxDecimals);
            }
          }
        }
        return s.replace(/\./g, "").replace(/[^\d]/g, "");
      }

      function parseViVnNumber(raw) {
        const s = String(raw ?? "").trim();
        if (s === "" || s === "." || s === ",") return NaN;
        const clean = vnRawToClean(s, 12);
        if (clean === "" || clean === ".") return NaN;
        const n = Number(clean);
        return Number.isFinite(n) ? n : NaN;
      }

      function digitsBeforeCaret(s, caret) {
        let n = 0;
        const end = Math.min(caret ?? s.length, s.length);
        for (let i = 0; i < end; i++) {
          if (/\d/.test(s[i])) n++;
        }
        return n;
      }

      function caretFromDigitCount(s, digitCount) {
        if (digitCount <= 0) return 0;
        let n = 0;
        for (let i = 0; i < s.length; i++) {
          if (/\d/.test(s[i])) {
            n++;
            if (n === digitCount) return i + 1;
          }
        }
        return s.length;
      }

      function digitsInRange(s, start, end) {
        let n = 0;
        const a = Math.max(0, start);
        const b = Math.min(end, s.length);
        for (let i = a; i < b; i++) {
          if (/\d/.test(s[i])) n++;
        }
        return n;
      }

      /** Vị trí sau chữ số thứ n trong phần nguyên (trước dấu phẩy thập phân). */
      function caretAfterNthIntDigitVn(s, n) {
        if (n <= 0) return 0;
        const comma = s.indexOf(",");
        const limit = comma === -1 ? s.length : comma;
        let count = 0;
        for (let i = 0; i < limit; i++) {
          if (/\d/.test(s[i])) {
            count++;
            if (count === n) return i + 1;
          }
        }
        return limit;
      }

      /** Sau dấu phẩy thập phân: đặt caret sau fracDigits chữ số (0 = ngay sau phẩy). */
      function caretAfterFracDigitsVn(s, fracDigits) {
        const ci = s.indexOf(",");
        if (ci === -1) return s.length;
        if (fracDigits <= 0) return ci + 1;
        let count = 0;
        for (let i = ci + 1; i < s.length; i++) {
          if (/\d/.test(s[i])) {
            count++;
            if (count === fracDigits) return i + 1;
          }
        }
        return s.length;
      }

      function formatGroupedVnFromClean(clean, maxDecimals) {
        if (clean === "") return "";
        const onlyOneDot = clean.indexOf(".");
        let body = clean;
        if (onlyOneDot !== -1) {
          body =
            clean.slice(0, onlyOneDot + 1) + clean.slice(onlyOneDot + 1).replace(/\./g, "");
        }
        const endsWithDot = body.endsWith(".");
        const hasDot = body.includes(".");
        let intRaw;
        let fracRaw;
        if (!hasDot) {
          intRaw = body;
          fracRaw = "";
        } else {
          const parts = body.split(".");
          intRaw = parts[0] ?? "";
          fracRaw = (parts.slice(1).join("") || "").replace(/\D/g, "").slice(0, maxDecimals);
        }
        let intDigits = String(intRaw).replace(/\D/g, "");
        if (intDigits === "") {
          if (hasDot) intDigits = "0";
          else return "";
        }
        intDigits = intDigits.replace(/^0+(?=\d)/, "");
        if (intDigits === "") intDigits = "0";
        const intFmt = intDigits.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        if (!hasDot) return intFmt;
        if (fracRaw.length > 0) return `${intFmt},${fracRaw}`;
        if (endsWithDot) return `${intFmt},`;
        return `${intFmt},${fracRaw}`;
      }

      function handleVnNumberInput(el, maxDecimals) {
        const prev = el.value;
        const sel = el.selectionStart ?? prev.length;
        const commaIdx = prev.lastIndexOf(",");

        const clean = vnRawToClean(prev, maxDecimals);
        const next = formatGroupedVnFromClean(clean, maxDecimals);

        let pos;
        if (commaIdx === -1) {
          pos = caretFromDigitCount(next, digitsBeforeCaret(prev, sel));
        } else if (sel > commaIdx) {
          pos = caretAfterFracDigitsVn(
            next,
            digitsInRange(prev, commaIdx + 1, sel),
          );
        } else {
          pos = caretAfterNthIntDigitVn(
            next,
            digitsInRange(prev, 0, Math.min(sel, commaIdx)),
          );
        }

        el.value = next;
        requestAnimationFrame(() => {
          el.setSelectionRange(pos, pos);
        });
      }

      document.querySelectorAll(".js-vn-number").forEach((el) => {
        const maxDec = el.classList.contains("js-vn-term") ? 0 : 2;
        el.addEventListener("input", () => handleVnNumberInput(el, maxDec));
      });

      function syncLoanLimitUnitUi() {
        const vnd = loanLimitUnitSelect.value === "vnd";
        loanLimitValueInput.placeholder = vnd ? "Ví dụ: 50.000.000" : "Ví dụ: 50";
        if (loanLimitUnitLabelEl) loanLimitUnitLabelEl.textContent = vnd ? "VNĐ" : "%";
      }

      loanLimitUnitSelect.addEventListener("change", syncLoanLimitUnitUi);
      syncLoanLimitUnitUi();

      function syncLoanTermUnitUi() {
        const years = loanTermUnitSelect.value === "years";
        loanTermValueInput.placeholder = years ? "Ví dụ: 20" : "Ví dụ: 240";
        if (loanTermUnitLabelEl) loanTermUnitLabelEl.textContent = years ? "năm" : "tháng";
      }

      let prevLoanTermUnit = loanTermUnitSelect.value;

      loanTermUnitSelect.addEventListener("change", () => {
        const cur = loanTermUnitSelect.value;
        if (cur !== prevLoanTermUnit) {
          const raw = parseViVnNumber(loanTermValueInput.value);
          let v = Number.isFinite(raw) ? Math.floor(Math.max(1, raw)) : 240;
          if (prevLoanTermUnit === "months" && cur === "years") {
            v = Math.max(1, Math.round(v / 12));
            loanTermValueInput.value = formatGroupedVnFromClean(String(v), 0);
          } else if (prevLoanTermUnit === "years" && cur === "months") {
            v = Math.min(600, Math.max(1, v * 12));
            loanTermValueInput.value = formatGroupedVnFromClean(String(v), 0);
          }
          prevLoanTermUnit = cur;
        }
        syncLoanTermUnitUi();
      });
      syncLoanTermUnitUi();

      /**
       * Chuẩn hóa hạn mức vay: luôn trả về { loanPct, loanPrincipal } để dùng thống nhất cho lịch trả nợ / kết quả năm đầu.
       * VND → quy đổi % = min(100, số tiền / giá mua × 100); gốc vay = giá mua × % đó.
       */
      function resolveLoanFromLimitInputs(purchasePrice, rawParsed, unit) {
        const price = Math.max(0, purchasePrice);
        if (unit === "vnd") {
          const amountVnd = Number.isFinite(rawParsed) ? Math.max(0, rawParsed) : 0;
          const loanPct =
            price > 0 ? Math.min(100, (amountVnd / price) * 100) : 0;
          const loanPrincipal = price * (loanPct / 100);
          return { loanPct, loanPrincipal };
        }
        const loanPct = Number.isFinite(rawParsed)
          ? Math.min(100, Math.max(0, rawParsed))
          : 0;
        const loanPrincipal = price * (loanPct / 100);
        return { loanPct, loanPrincipal };
      }

      const ddBase = "mt-1 text-lg font-semibold ";

      const alertThemeClasses = [
        "text-red-200",
        "bg-red-500/10",
        "ring-red-500/25",
        "text-emerald-200",
        "bg-emerald-500/10",
        "ring-emerald-500/25",
      ];

      function hideInvestorCalcAlert() {
        investorCalcAlertEl.textContent = "";
        investorCalcAlertEl.classList.add("hidden");
        investorCalcAlertEl.classList.remove(...alertThemeClasses);
      }

      /**
       * Logic (JS): Trả góp đều — M = [P*r*(1+r)^n] / [(1+r)^n - 1]. P: gốc, r: lãi tháng, n: số tháng.
       */
      function annuityMonthlyPayment(P, r, n) {
        if (P <= 0 || n < 1) return 0;
        if (r <= 0) return P / n;
        const pow = Math.pow(1 + r, n);
        return (P * r * pow) / (pow - 1);
      }

      /** Logic (JS): Dư nợ giảm dần — gốc mỗi tháng = P/n; lãi tháng i = dư đầu kỳ × r. */
      function buildDecliningSchedule(P, r, n, maxRows) {
        const rows = [];
        if (P <= 0 || n < 1) return rows;
        const principalMonthly = P / n;
        let balance = P;
        const limit = Math.min(maxRows, n);
        for (let m = 1; m <= limit; m++) {
          const interest = balance * r;
          let principalPay = principalMonthly;
          if (m === n) principalPay = balance;
          const total = principalPay + interest;
          balance = Math.max(0, balance - principalPay);
          rows.push({ month: m, principal: principalPay, interest, total, balanceEnd: balance });
        }
        return rows;
      }

      function buildAnnuitySchedule(P, r, n, maxRows) {
        const rows = [];
        if (P <= 0 || n < 1) return rows;
        const payment = annuityMonthlyPayment(P, r, n);
        let balance = P;
        const limit = Math.min(maxRows, n);
        for (let m = 1; m <= limit; m++) {
          const interest = balance * r;
          let principalPay = payment - interest;
          if (principalPay > balance) principalPay = balance;
          if (m === n) principalPay = balance;
          const total = principalPay + interest;
          balance = Math.max(0, balance - principalPay);
          rows.push({ month: m, principal: principalPay, interest, total, balanceEnd: balance });
        }
        return rows;
      }

      function sumPayFirst12(rows) {
        return rows.reduce((s, row) => s + row.total, 0);
      }

      function sumInterestFirst12(rows) {
        return rows.reduce((s, row) => s + row.interest, 0);
      }

      function sumPrincipalFirst12(rows) {
        return rows.reduce((s, row) => s + row.principal, 0);
      }

      function renderLoanScheduleTable(rows) {
        loanScheduleBodyEl.textContent = "";
        const frag = document.createDocumentFragment();
        for (const row of rows) {
          const tr = document.createElement("tr");
          tr.className = "bg-slate-950/25 hover:bg-slate-950/45";
          const specs = [
            { text: String(row.month), extra: "" },
            { text: formatViVnAmount(row.principal), extra: "" },
            { text: formatViVnAmount(row.interest), extra: "" },
            { text: formatViVnAmount(row.total), extra: "font-medium text-slate-100" },
            { text: formatViVnAmount(row.balanceEnd), extra: "" },
          ];
          for (const spec of specs) {
            const td = document.createElement("td");
            td.className =
              "whitespace-nowrap px-3 py-2 tabular-nums" +
              (spec.extra ? ` ${spec.extra}` : "");
            td.textContent = spec.text;
            tr.appendChild(td);
          }
          frag.appendChild(tr);
        }
        loanScheduleBodyEl.appendChild(frag);
      }

      /** Quy đổi kỳ hạn nhập → n (số tháng) cho annuity / declining. Năm × 12, tối đa 600 tháng. */
      function readLoanTermMonths() {
        const raw = parseViVnNumber(loanTermValueInput.value);
        let v = Number.isFinite(raw) ? Math.floor(Math.max(0, raw)) : NaN;
        if (!Number.isFinite(v) || v < 1) return 240;
        const months =
          loanTermUnitSelect.value === "years" ? v * 12 : v;
        return Math.min(600, Math.max(1, months));
      }

      deepCalcBtn.addEventListener("click", () => {
        const purchasePrice = Math.max(0, parseViVnNumber(aptPurchaseInput.value) || 0);
        const monthlyRent = Math.max(0, parseViVnNumber(aptRentInput.value) || 0);
        const annualRatePct = parseViVnNumber(bankRateInput.value);
        const annualRate = Number.isFinite(annualRatePct) ? Math.max(0, annualRatePct) : 0;

        const rawLoanLimit = parseViVnNumber(loanLimitValueInput.value);
        const { loanPrincipal } = resolveLoanFromLimitInputs(
          purchasePrice,
          rawLoanLimit,
          loanLimitUnitSelect.value,
        );
        const equity = purchasePrice - loanPrincipal;
        const n = readLoanTermMonths();
        const r = annualRate / 100 / 12;
        const mode = loanRepaymentModeSelect.value === "declining" ? "declining" : "annuity";

        let scheduleRows = [];
        /*
         * Thu chi năm đầu = (tiền thuê tháng × 12) − (tổng gốc trả NH 12 tháng + tổng lãi trả NH 12 tháng).
         * Lợi nhuận năm đầu = (tiền thuê tháng × 12) − (tổng lãi vay 12 tháng đầu).
         * Tỉ suất lợi nhuận năm đầu = (lợi nhuận ròng năm 1 / vốn tự có) × 100; vốn tự có = giá mua − gốc vay.
         * Trả góp đều (annuity): từng tháng gốc+lãi theo M chuẩn; dư nợ giảm dần: gốc P/n + lãi trên dư đầu kỳ.
         */
        let thuChiNamDau = monthlyRent * 12;
        let loiNhuanNamDau = monthlyRent * 12;
        let principal12 = 0;
        let interest12 = 0;
        let paid12 = 0;
        let balanceEnd12 = 0;

        const hintThuChi =
          "Số tiền cho thuê nhà năm đầu − tổng tiền gốc và lãi năm đầu.";
        const hintLoiNhuan =
          "Số tiền cho thuê năm đầu − số tiền lãi vay ngân hàng 12 tháng đầu.";

        if (loanPrincipal > 0 && n >= 1) {
          scheduleRows =
            mode === "declining"
              ? buildDecliningSchedule(loanPrincipal, r, n, 12)
              : buildAnnuitySchedule(loanPrincipal, r, n, 12);

          paid12 = sumPayFirst12(scheduleRows);
          interest12 = sumInterestFirst12(scheduleRows);
          principal12 = sumPrincipalFirst12(scheduleRows);
          thuChiNamDau = monthlyRent * 12 - paid12;
          loiNhuanNamDau = monthlyRent * 12 - interest12;
          const lastRow = scheduleRows[scheduleRows.length - 1];
          balanceEnd12 = lastRow ? lastRow.balanceEnd : loanPrincipal;

          resultNetMonthlyHintEl.textContent = hintThuChi;
          resultRoiHintEl.textContent = hintLoiNhuan;
        } else {
          resultNetMonthlyHintEl.textContent =
            loanPrincipal <= 0 ? hintThuChi : "Nhập kỳ hạn vay hợp lệ để tính lịch trả.";
          resultRoiHintEl.textContent = loanPrincipal <= 0 ? hintLoiNhuan : "";
          loanScheduleWrapperEl.classList.add("hidden");
        }

        resultNetMonthlyEl.textContent = `${formatViVnAmount(thuChiNamDau)} VNĐ`;

        if (thuChiNamDau < 0) {
          resultNetMonthlyEl.className = ddBase + "text-red-400";
        } else if (thuChiNamDau > 0) {
          resultNetMonthlyEl.className = ddBase + "text-emerald-300";
        } else {
          resultNetMonthlyEl.className = ddBase + "text-slate-200";
        }

        resultRoiAnnualEl.textContent = `${formatViVnAmount(loiNhuanNamDau)} VNĐ`;
        if (loiNhuanNamDau < 0) {
          resultRoiAnnualEl.className = ddBase + "text-red-400";
        } else if (loiNhuanNamDau > 0) {
          resultRoiAnnualEl.className = ddBase + "text-emerald-300";
        } else {
          resultRoiAnnualEl.className = ddBase + "text-slate-200";
        }

        const tongThue = monthlyRent * 12;
        resultYear1BreakdownEl.classList.remove("hidden");
        resultY1TotalRentEl.textContent = `${formatViVnAmount(tongThue)} VNĐ`;
        resultY1PrincipalPaidEl.textContent = `${formatViVnAmount(principal12)} VNĐ`;
        resultY1InterestPaidEl.textContent = `${formatViVnAmount(interest12)} VNĐ`;
        resultY1PrincipalInterestPaidEl.textContent = `${formatViVnAmount(paid12)} VNĐ`;
        resultY1BalanceEndEl.textContent = `${formatViVnAmount(balanceEnd12)} VNĐ`;
        if (equity > 0) {
          const tiSuat = (loiNhuanNamDau / equity) * 100;
          resultY1ProfitMarginEl.textContent = `${formatViVnAmount(tiSuat)} %`;
          if (tiSuat < 0) {
            resultY1ProfitMarginEl.className = "font-medium tabular-nums text-red-400";
          } else if (tiSuat > 0) {
            resultY1ProfitMarginEl.className = "font-medium tabular-nums text-emerald-300";
          } else {
            resultY1ProfitMarginEl.className = "font-medium tabular-nums text-slate-100";
          }
        } else {
          resultY1ProfitMarginEl.textContent =
            "— (vốn tự có = 0, không chia tỉ suất theo vốn)";
          resultY1ProfitMarginEl.className = "font-medium tabular-nums text-slate-100";
        }

        if (loanPrincipal > 0 && scheduleRows.length > 0) {
          renderLoanScheduleTable(scheduleRows);
          loanScheduleWrapperEl.classList.remove("hidden");
        } else {
          loanScheduleBodyEl.textContent = "";
          loanScheduleWrapperEl.classList.add("hidden");
        }

        investorCalcAlertEl.classList.remove("hidden", ...alertThemeClasses);

        if (thuChiNamDau < 0) {
          investorCalcAlertEl.classList.add(
            "text-red-200",
            "bg-red-500/10",
            "ring-red-500/25",
          );
          investorCalcAlertEl.textContent =
            "Cảnh báo: Thu chi năm đầu đang âm (12 tháng tiền thuê thấp hơn tổng gốc và lãi trả trong 12 tháng đầu). Hãy xem lại lãi suất, kỳ hạn, phương thức trả nợ, hạn mức vay hoặc giá thuê dự kiến.";
        } else if (thuChiNamDau > 0) {
          investorCalcAlertEl.classList.add(
            "text-emerald-200",
            "bg-emerald-500/10",
            "ring-emerald-500/25",
          );
          investorCalcAlertEl.textContent = "Đầu tư tốt";
        } else {
          hideInvestorCalcAlert();
        }
      });
    </script>
  </body>
</html>
